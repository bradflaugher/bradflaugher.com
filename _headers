# Best practice cache control for Cloudflare Pages

# Default: always revalidate HTML and other files
/*
  Cache-Control: public, max-age=0, must-revalidate

# Immutable assets: long-lived cache for hashed files
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.onnx
  Cache-Control: public, max-age=31536000, immutable

/*.json
  Cache-Control: public, max-age=31536000, immutable

# Standard assets (fonts, icons) - cache for 1 week
/fonts/*
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/search.webmanifest
  Cache-Control: public, max-age=604800
